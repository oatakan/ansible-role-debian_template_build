#!/usr/bin/env bash
set -euo pipefail

log() {
    printf 'grow_part: %s\n' "$*"
}

have() {
    command -v "$1" >/dev/null 2>&1
}

require() {
    if ! have "$1"; then
        log "required command not found: $1"
        exit 1
    fi
}

resolve_device() {
    local device="$1"

    if [ -e "$device" ]; then
        readlink -f "$device"
        return
    fi

    printf '%s\n' "$device"
}

partition_parent() {
    local partition="$1"
    local parent
    local partnum

    parent="$(lsblk -ndo PKNAME "$partition" 2>/dev/null | tr -d '[:space:]')"
    partnum="$(lsblk -ndo PARTN "$partition" 2>/dev/null | tr -d '[:space:]')"

    if [ -z "$parent" ] || [ -z "$partnum" ]; then
        return 1
    fi

    printf '/dev/%s %s\n' "$parent" "$partnum"
}

grow_partition() {
    local partition="$1"
    local parent_info
    local disk
    local partnum
    local output
    local status

    if ! parent_info="$(partition_parent "$partition")"; then
        log "$partition is not a growable partition; skipping partition resize"
        return 0
    fi

    disk="$(printf '%s\n' "$parent_info" | awk '{print $1}')"
    partnum="$(printf '%s\n' "$parent_info" | awk '{print $2}')"

    log "growing partition $partition on $disk partition $partnum"
    set +e
    output="$(growpart --update=auto "$disk" "$partnum" 2>&1)"
    status=$?
    set -e
    printf '%s\n' "$output"

    if [ "$status" -eq 0 ]; then
        return 0
    fi

    if printf '%s\n' "$output" | grep -qi 'NOCHANGE'; then
        log "partition $partition already uses available disk space"
        return 0
    fi

    return "$status"
}

resize_filesystem() {
    local device="$1"
    local fstype="$2"
    local mountpoint="$3"

    case "$fstype" in
        ext2|ext3|ext4)
            require resize2fs
            log "resizing $fstype filesystem on $device"
            resize2fs "$device"
            ;;
        xfs)
            require xfs_growfs
            log "resizing xfs filesystem mounted at $mountpoint"
            xfs_growfs "$mountpoint"
            ;;
        btrfs)
            require btrfs
            log "resizing btrfs filesystem mounted at $mountpoint"
            btrfs filesystem resize max "$mountpoint"
            ;;
        *)
            log "unsupported root filesystem type: $fstype"
            exit 1
            ;;
    esac
}

resize_lvm_root() {
    local root_device="$1"
    local root_fstype="$2"
    local root_mount="$3"
    local lv_path
    local vg_name
    local pv_name
    local free_bytes

    require lvs
    require pvs
    require vgs
    require pvresize
    require lvextend

    lv_path="$(lvs --noheadings -o lv_path "$root_device" 2>/dev/null | awk '{print $1; exit}')"
    vg_name="$(lvs --noheadings -o vg_name "$root_device" 2>/dev/null | awk '{print $1; exit}')"

    if [ -z "$lv_path" ] || [ -z "$vg_name" ]; then
        log "could not resolve LVM root from $root_device"
        exit 1
    fi

    pv_name="$(pvs --noheadings -o pv_name,vg_name 2>/dev/null | awk -v vg="$vg_name" '$2 == vg {print $1; exit}')"
    if [ -z "$pv_name" ]; then
        log "could not find a physical volume for volume group $vg_name"
        exit 1
    fi

    pv_name="$(resolve_device "$pv_name")"
    grow_partition "$pv_name"

    log "resizing physical volume $pv_name"
    pvresize "$pv_name"

    free_bytes="$(vgs --noheadings --units b --nosuffix -o vg_free "$vg_name" | awk '{printf "%.0f", $1}')"
    if [ "${free_bytes:-0}" -gt 0 ]; then
        log "extending logical volume $lv_path with ${free_bytes} bytes of free space"
        lvextend -l +100%FREE "$lv_path"
    else
        log "volume group $vg_name has no free extents to assign"
    fi

    resize_filesystem "$lv_path" "$root_fstype" "$root_mount"
}

resize_partition_root() {
    local root_device="$1"
    local root_fstype="$2"
    local root_mount="$3"

    grow_partition "$root_device"
    resize_filesystem "$root_device" "$root_fstype" "$root_mount"
}

main() {
    local root_mount="/"
    local root_source
    local root_device
    local root_fstype
    local root_type

    require findmnt
    require lsblk
    require growpart

    root_source="$(findmnt -n -o SOURCE --target "$root_mount")"
    root_fstype="$(findmnt -n -o FSTYPE --target "$root_mount")"
    root_device="$(resolve_device "$root_source")"
    root_type="$(lsblk -ndo TYPE "$root_device" 2>/dev/null | tr -d '[:space:]')"

    log "root source=$root_source resolved=$root_device type=${root_type:-unknown} fstype=$root_fstype"

    case "$root_type" in
        lvm)
            resize_lvm_root "$root_device" "$root_fstype" "$root_mount"
            ;;
        part)
            resize_partition_root "$root_device" "$root_fstype" "$root_mount"
            ;;
        *)
            log "unsupported root block device type: ${root_type:-unknown}"
            exit 1
            ;;
    esac
}

main "$@"
